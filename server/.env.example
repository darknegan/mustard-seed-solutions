# Copy to .env in this folder (server/.env) and set real values.
# server/.env is gitignored.

PORT=3000

# Random string for signing tokens (use a long unpredictable value in production).
JWT_SECRET=

# Project URL only: https://YOUR_PROJECT_REF.supabase.co
# (Supabase dashboard → Project Settings → API → "Project URL". Not the dashboard URL in the browser.)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TLS_SKIP_VERIFY=true
DATABASE_URL=

# For `npm run migrate`: Postgres URI (NOT the REST Project URL above).
# In the dashboard: **Connect** → **Session pooler** URI (port 5432) if your network is IPv4-only
# or you see ENETUNREACH — direct `db.*.supabase.co` is often IPv6-only. **Direct** is fine when IPv6 works.
# Copy the **URI** (postgresql:// or postgres://). Paste your DB password when prompted.
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres

# Migrate only: DNS for this Node process. Default (when unset) is 8.8.8.8 + 1.1.1.1 so broken local stubs
# (timeouts on 127.0.0.x) do not cause ENOTFOUND. Use empty value to keep system resolvers: DATABASE_DNS_SERVERS=
# DATABASE_DNS_SERVERS=10.0.0.1,10.0.0.2

# TLS (Windows / corporate proxy): npm scripts use node --use-system-ca.
# If `npm install` in server/ fails with UNABLE_TO_VERIFY_LEAF_SIGNATURE, in PowerShell run:
#   $env:NODE_OPTIONS='--use-system-ca'
# then `npm install` again. Or set NODE_EXTRA_CA_CERTS to a PEM bundle (preferred).
# If Supabase still fails with UNABLE_TO_VERIFY_LEAF_SIGNATURE, either:
# - export your org CA as PEM and set NODE_EXTRA_CA_CERTS=C:\path\to\corp-ca.pem
# - or for local dev only, set the line below (never in production; server refuses if NODE_ENV=production)
# SUPABASE_TLS_SKIP_VERIFY=true
