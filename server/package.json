{
  "name": "mustard-seed-solutions-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --use-system-ca ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "tsc",
    "start": "node --use-system-ca dist/index.js",
    "migrate": "node --use-system-ca ./node_modules/tsx/dist/cli.mjs src/db/migrate.ts",
    "install:all": "npm install && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.0",
    "pg": "^8.14.1",
    "pg-connection-string": "^2.12.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
