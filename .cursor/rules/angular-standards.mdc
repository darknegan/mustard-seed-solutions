## Performance Best Practices

### trackBy Functions

**Always use trackBy in loops**

```html
<!-- ✅ DO: track by unique id in @for -->
@for (member of members(); track member.id) {
<app-member-card [member]="member" />
}

<!-- ✅ DO: track $index for primitive arrays -->
@for (tag of tags(); track $index) {
<span class="tag">{{ tag }}</span>
}
```

### Pure Pipes

**Create pure pipes for transformations**

```typescript
import { Pipe, PipeTransform } from '@angular/core';

// ✅ DO: pure pipe (default) for any value transformation
@Pipe({
  name: 'truncate',
  standalone: true,
  pure: true, // default — explicit for clarity
})
export class TruncatePipe implements PipeTransform {
  transform(value: string, maxLength: number = 100): string {
    return value.length > maxLength ? `${value.slice(0, maxLength)}…` : value;
  }
}
```

```html
<!-- Usage -->
<p>{{ sermon.description | truncate:120 }}</p>
```

### Lazy Loading

**Lazy load feature routes**

```typescript
// ✅ DO: lazy-load feature routes with loadComponent / loadChildren
export const routes: Routes = [
  {
    path: '',
    loadComponent: () =>
      import('./home/home.component').then(m => m.HomeComponent),
  },
  {
    path: 'sermons',
    loadChildren: () =>
      import('./sermons/sermons.routes').then(m => m.SERMON_ROUTES),
  },
  {
    path: 'about',
    loadComponent: () =>
      import('./about/about.component').then(m => m.AboutComponent),
  },
];

// ❌ DON'T: eagerly import feature components in the root routes
import { SermonsComponent } from './sermons/sermons.component';
{ path: 'sermons', component: SermonsComponent }
```
